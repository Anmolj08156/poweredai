# ─── StudNexus environment ───────────────────────────────────────────────
# Copy to `.env.local` and fill in. All keys are optional; the site works
# fully without any of them. Only VITE_*-prefixed vars are exposed to the app.

# Public site URL (used for canonical/OG if you template them)
VITE_SITE_URL=https://studnexus.com

# Analytics (each loads only if its id/key is present)
VITE_GA_ID=
VITE_CLARITY_ID=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Waitlist: signups are POSTed here (Google Apps Script Web App) in addition to
# local storage. A working default is already baked into src/lib/config.ts, so
# this is only needed to OVERRIDE it for a different sheet/backend.
VITE_WAITLIST_ENDPOINT=https://script.google.com/macros/s/AKfycbxgb_5tjfz4rw1wafg5RezCXbzDVSExLneSo-m7ydCxUIdM9gl28BQbAibll0sBgml9hg/exec
